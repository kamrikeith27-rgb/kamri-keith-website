{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "^(?!.*\\.).*$",
      "destination": "/ui_kits/recruiting_site/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/photos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
