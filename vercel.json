{
  "name": "kamri-keith-website",
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "public": true,
  "routes": [
    {
      "src": "/ui_kits/recruiting_site/(.*)",
      "dest": "/ui_kits/recruiting_site/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {},
  "alias": ["kamri-keith.vercel.app"],
  "github": {
    "enabled": true,
    "autoAlias": true,
    "autoJobCancelPreviousOnPush": true
  }
}
