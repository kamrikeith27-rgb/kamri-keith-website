{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/data/**",
              "ui_kits/recruiting_site/**",
              "ui_kits/social_kit/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Anton|Oswald|Barlow|Barlow Semi Condensed|Grand Hotel))/i]",
        "message": "Font not provided by the design system. Available: Anton, Oswald, Barlow, Barlow Semi Condensed, Grand Hotel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|soft|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, soft, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:royal|ink|accent|clay|spirit)$/]",
        "message": "<Badge> tone must be one of 'royal' | 'ink' | 'accent' | 'clay' | 'spirit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|hard|full|as|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, hard, full, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|accent|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|pad|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, pad, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|hard|ink|royal)$/]",
        "message": "<Card> variant must be one of 'plain' | 'hard' | 'ink' | 'royal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|shape|tone|size|key|ref|className|style|children)$/]",
        "message": "<NumberMark> doesn't accept that prop. Declared props: value, shape, tone, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberMark'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|shield|plate)$/]",
        "message": "<NumberMark> shape must be one of 'circle' | 'shield' | 'plate'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberMark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:royal|ink|accent|outline|chalk)$/]",
        "message": "<NumberMark> tone must be one of 'royal' | 'ink' | 'accent' | 'outline' | 'chalk'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|unit|caption|variant|align|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, label, unit, caption, variant, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:plain|hard|ink|royal)$/]",
        "message": "<StatCard> variant must be one of 'plain' | 'hard' | 'ink' | 'royal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatCard> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|emphasis|key|ref|className|style|children)$/]",
        "message": "<StatLine> doesn't accept that prop. Declared props: label, value, emphasis."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:dot|active|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: dot, active, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
